# Copy to .env (never commit .env). Supabase → Project Settings → API.
#
# VITE_SUPABASE_URL = your project URL, e.g. https://xxxx.supabase.co
#
# VITE_SUPABASE_ANON_KEY = the browser-safe key ONLY:
#   - New projects: "Publishable" key (often starts with sb_publishable_)
#   - Older projects: "anon" "public" JWT (long string starting with eyJ)
#
# NEVER put the Secret / service key (sb_secret_...) in VITE_* or any file shipped
# to the browser — Supabase will reject it with "Forbidden use of secret API key in browser".

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
